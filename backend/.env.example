# Contra Backend Environment
# Copy to .env and fill in real values

# LLM Provider (adapter config — no vendor SDK outside llm_adapter.py)
LLM_PROVIDER=openai
LLM_API_KEY=sk-CHANGE_ME
LLM_MODEL=gpt-4o

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database (MSSQL via SQLAlchemy + pymssql — no ODBC driver required)
DATABASE_URL=mssql+pymssql://sa:Admin%401234@localhost:1433/contra
