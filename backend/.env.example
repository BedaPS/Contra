# =============================================================================
# Contra Backend — Environment Template
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
#
# Keys marked [GH SECRET] must also be set as GitHub Actions secrets for CI/CD.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
# [GH SECRET: DATABASE_URL]
# Local Docker Compose MSSQL:
DATABASE_URL=mssql+pymssql://sa:Admin%401234@localhost:1433/contra
# Azure SQL (production):
# DATABASE_URL=mssql+pymssql://<user>:<password>@<server>.database.windows.net:1433/contra

# ── CORS ─────────────────────────────────────────────────────────────────────
# [GH SECRET: CORS_ORIGINS]
# Local dev: http://localhost:4200
# Production: https://<your-app>.azurestaticapps.net
CORS_ORIGINS=http://localhost:4200

# ── Google OAuth ─────────────────────────────────────────────────────────────
# [GH SECRET: GOOGLE_CLIENT_ID]
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ── LLM Provider ─────────────────────────────────────────────────────────────
# [GH SECRET: LLM_PROVIDER]  options: stub | openai | azure_openai | anthropic
LLM_PROVIDER=stub

# [GH SECRET: LLM_API_KEY]
LLM_API_KEY=YOUR_LLM_API_KEY_HERE

# [GH SECRET: LLM_MODEL]  e.g. gpt-4o, claude-3-5-sonnet-20241022
LLM_MODEL=

# Base URL — only required for azure_openai or self-hosted (Ollama/vLLM)
LLM_BASE_URL=
