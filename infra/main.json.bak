              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "managedEnvironmentId": "[parameters('environmentId')]",
                "workloadProfileName": "Consumption",
                "configuration": {
                  "activeRevisionsMode": "Single",
                  "ingress": {
                    "external": true,
                    "targetPort": 8000,
                    "transport": "http",
                    "allowInsecure": false,
                    "corsPolicy": {
                      "allowedOrigins": [
                        "[parameters('corsOrigins')]"
                      ],
                      "allowedMethods": [
                        "GET",
                        "POST",
                        "PUT",
                        "DELETE",
                        "OPTIONS"
                      ],
                      "allowedHeaders": [
                        "*"
                      ],
                      "maxAge": 3600
                    }
                  },
                  "secrets": [
                    {
                      "name": "database-url",
                      "value": "[parameters('databaseUrl')]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "contra-backend",
                      "image": "[parameters('containerImage')]",
                      "resources": {
                        "cpu": "[json('0.25')]",
                        "memory": "0.5Gi"
                      },
                      "env": [
                        {
                          "name": "DATABASE_URL",
                          "secretRef": "database-url"
                        },
                        {
                          "name": "LLM_PROVIDER",
                          "value": "stub"
                        },
                        {
                          "name": "LLM_API_KEY",
                          "value": ""
                        },
                        {
                          "name": "LLM_MODEL",
                          "value": ""
                        },
                        {
                          "name": "CORS_ORIGINS",
                          "value": "[parameters('corsOrigins')]"
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 0,
                    "maxReplicas": 1
                  }
                }
              }
            }
          ],
