# Contra Backend Environment
# Copy to .env and fill in real values

# LLM Provider — configured via Settings UI or env vars below
# Supported: gemini | openai | anthropic | local | stub
LLM_PROVIDER=gemini
LLM_API_KEY=YOUR_API_KEY_HERE
LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=
# LLM_BASE_URL is only needed for "local" provider (Ollama/vLLM)
# e.g. http://localhost:11434/v1

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database (MSSQL via SQLAlchemy + pymssql — no ODBC driver required)
DATABASE_URL=mssql+pymssql://sa:Admin%401234@localhost:1433/contra

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:4200
